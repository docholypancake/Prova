          "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{tokenB}}", "type": "string" }] }, "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"title\": \"hax\"\n}" }, "url": { "raw": "{{API}}/api/cases/{{caseId}}", "host": ["{{API}}"], "path": ["api", "cases", "{{caseId}}"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('401 or 403', () => pm.expect([401,403]).to.include(pm.response.code));"
          ] } }]
        }
