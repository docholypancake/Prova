          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201', () => pm.response.to.have.status(201));",
            "const run = pm.response.json().run;",
            "pm.collectionVariables.set('runId', run._id);",
            "pm.test('1 case pending', () => { pm.expect(run.cases.length).to.eql(1); pm.expect(run.cases[0].result).to.eql('pending'); });",
            "pm.test('has shareToken', () => pm.expect(run.shareToken).to.be.a('string'));"
          ] } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Regression run\",\n  \"selectedCaseIds\": [\"{{caseId}}\"]\n}" }, "url": { "raw": "{{API}}/api/projects/{{projectId}}/runs", "host": ["{{API}}"], "path": ["api", "projects", "{{projectId}}", "runs"] } }
        },
        {
          "name": "R4 GET run (populated) -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "pm.test('case populated', () => pm.expect(pm.response.json().run.cases[0].testCaseId).to.have.property('title'));"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{API}}/api/runs/{{runId}}", "host": ["{{API}}"], "path": ["api", "runs", "{{runId}}"] } }
        },
        {
          "name": "R5 PUT case result passed -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "pm.test('passed', () => { const c = pm.response.json().run.cases[0]; pm.expect(c.result).to.eql('passed'); });"
          ] } }],
          "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"result\": \"passed\"\n}" }, "url": { "raw": "{{API}}/api/runs/{{runId}}/cases/{{caseId}}", "host": ["{{API}}"], "path": ["api", "runs", "{{runId}}", "cases", "{{caseId}}"] } }
        },
        {
          "name": "R6 PUT bad result -> 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('400', () => pm.response.to.have.status(400));"
          ] } }],
          "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"result\": \"explode\"\n}" }, "url": { "raw": "{{API}}/api/runs/{{runId}}/cases/{{caseId}}", "host": ["{{API}}"], "path": ["api", "runs", "{{runId}}", "cases", "{{caseId}}"] } }
        },
        {
          "name": "R7 POST complete -> 200 (passed)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "pm.test('status passed', () => pm.expect(pm.response.json().run.status).to.eql('passed'));"
          ] } }],
          "request": { "method": "POST", "url": { "raw": "{{API}}/api/runs/{{runId}}/complete", "host": ["{{API}}"], "path": ["api", "runs", "{{runId}}", "complete"] } }
        },
        {
          "name": "R8 POST upload no image -> 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('400 validation', () => pm.response.to.have.status(400));"
          ] } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{}" }, "url": { "raw": "{{API}}/api/upload", "host": ["{{API}}"], "path": ["api", "upload"] } }
        }
      ]
    },
    {
      "name": "7. Guards (no auth)",
      "description": "Order-independent.",
      "item": [
        {
          "name": "A1 GET projects no auth -> 401",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{API}}/api/projects", "host": ["{{API}}"], "path": ["api", "projects"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('401', () => pm.response.to.have.status(401));"
          ] } }]
        },
        {
          "name": "A2 garbage token -> 401",
          "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "garbage.jwt.value", "type": "string" }] }, "method": "GET", "url": { "raw": "{{API}}/api/projects", "host": ["{{API}}"], "path": ["api", "projects"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('401', () => pm.response.to.have.status(401));"
          ] } }]
        },
        {
          "name": "A3 GET /auth/me no auth -> 401",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{API}}/auth/me", "host": ["{{API}}"], "path": ["auth", "me"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('401', () => pm.response.to.have.status(401));"
          ] } }]
        }
      ]
    },
    {
      "name": "8. Cleanup (cascade)",
      "item": [
        {
          "name": "C13 DELETE case -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));"
          ] } }],
          "request": { "method": "DELETE", "url": { "raw": "{{API}}/api/cases/{{caseId}}", "host": ["{{API}}"], "path": ["api", "cases", "{{caseId}}"] } }
        },
        {
          "name": "S13 DELETE suite (cascade) -> 200, deletedSuites 2",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "pm.test('deleted parent + child', () => pm.expect(pm.response.json().deletedSuites).to.eql(2));"
          ] } }],
          "request": { "method": "DELETE", "url": { "raw": "{{API}}/api/suites/{{suiteId}}", "host": ["{{API}}"], "path": ["api", "suites", "{{suiteId}}"] } }
        },
        {
          "name": "P15 DELETE project (cascade) -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));"
          ] } }],
          "request": { "method": "DELETE", "url": { "raw": "{{API}}/api/projects/{{projectId}}", "host": ["{{API}}"], "path": ["api", "projects", "{{projectId}}"] } }
        },
        {
          "name": "P17 POST create again (slot freed) -> 201",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201', () => pm.response.to.have.status(201));",
