# Production env — set these in the Railway/Render dashboard. NEVER commit real values.
NODE_ENV=production
MONGO_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
JWT_SECRET=
# Vercel client domain (used for CORS + OAuth redirect):
CLIENT_URL=https://your-app.vercel.app
WEBHOOK_SECRET=
# Public API domain + /webhooks/github:
WEBHOOK_URL=https://your-api.up.railway.app/webhooks/github
# Public API base URL (used for OAuth callback + report links):
APP_URL=https://your-api.up.railway.app
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Railway/Render inject PORT automatically; index.js reads process.env.PORT.
