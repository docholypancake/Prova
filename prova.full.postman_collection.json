{
  "info": {
    "name": "Prova API — Full Test Plan",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Every TEST_PLAN case (A/P/S/C) + Day 3 Runs + upload, as runnable requests with pm.test assertions.\n\nSETUP: select env 'Prova — Local', set `token` to your prova_token JWT. Optional: set `tokenB` to a SECOND user's JWT for true 403 ownership checks (without it, those requests get 401 — still proves access denied; assertions accept 401 or 403).\n\nRUN: Collection Runner, top-to-bottom. Folder 0 resets your projects so the free-tier checks are deterministic. The suite runs end-to-end and cleans up after itself."
  },
  "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
  "variable": [
    { "key": "projectId", "value": "" },
    { "key": "suiteId", "value": "" },
    { "key": "childSuiteId", "value": "" },
    { "key": "caseId", "value": "" },
    { "key": "runId", "value": "" },
    { "key": "missingId", "value": "000000000000000000000000" }
  ],
  "item": [
    {
      "name": "0. Reset (delete existing projects)",
      "item": [
        {
          "name": "Reset projects",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 list', () => pm.response.to.have.status(200));",
            "const projects = pm.response.json().projects || [];",
            "let done = 0;",
            "if (projects.length === 0) { pm.test('nothing to reset', () => pm.expect(true).to.be.true); }",
            "projects.forEach((p) => {",
            "  pm.sendRequest({ url: pm.environment.get('API') + '/api/projects/' + p._id, method: 'DELETE', header: { Authorization: 'Bearer ' + pm.environment.get('token') } }, (err, res) => {",
            "    done++;",
            "    if (done === projects.length) pm.test('reset ' + projects.length + ' project(s)', () => pm.expect(true).to.be.true);",
            "  });",
            "});"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{API}}/api/projects", "host": ["{{API}}"], "path": ["api", "projects"] } }
        }
      ]
    },
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "A4 GET /auth/me -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "pm.test('has user', () => pm.expect(pm.response.json()).to.have.property('user'));"
          ] } }],
          "request": { "method": "GET", "url": { "raw": "{{API}}/auth/me", "host": ["{{API}}"], "path": ["auth", "me"] } }
        }
      ]
    },
    {
      "name": "2. Projects",
      "item": [
        {
          "name": "P3 POST no name -> 400",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('400', () => pm.response.to.have.status(400));",
            "pm.test('errors present', () => pm.expect(pm.response.json()).to.have.property('errors'));"
          ] } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{}" }, "url": { "raw": "{{API}}/api/projects", "host": ["{{API}}"], "path": ["api", "projects"] } }
        },
        {
          "name": "P4 POST create -> 201",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('201', () => pm.response.to.have.status(201));",
            "const p = pm.response.json().project;",
            "pm.collectionVariables.set('projectId', p._id);",
            "pm.test('name', () => pm.expect(p.name).to.eql('Proj A'));"
          ] } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Proj A\",\n  \"description\": \"first\"\n}" }, "url": { "raw": "{{API}}/api/projects", "host": ["{{API}}"], "path": ["api", "projects"] } }
        },
        {
          "name": "P5 POST 2nd (free tier) -> 403",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('403 free-tier cap', () => pm.response.to.have.status(403));"
          ] } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Proj B\"\n}" }, "url": { "raw": "{{API}}/api/projects", "host": ["{{API}}"], "path": ["api", "projects"] } }
        },
