    {
      "name": "5. Ownership 403 (needs tokenB)",
      "description": "Set env `tokenB` to a SECOND user's JWT for real 403. Without it requests are unauthenticated -> 401. Assertions accept 401 or 403 (both prove access denied).",
      "item": [
        {
          "name": "P8 GET project as non-owner",
          "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{tokenB}}", "type": "string" }] }, "method": "GET", "url": { "raw": "{{API}}/api/projects/{{projectId}}", "host": ["{{API}}"], "path": ["api", "projects", "{{projectId}}"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('401 or 403', () => pm.expect([401,403]).to.include(pm.response.code));"
          ] } }]
        },
        {
          "name": "S2 GET suites as non-owner",
          "request": { "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{tokenB}}", "type": "string" }] }, "method": "GET", "url": { "raw": "{{API}}/api/projects/{{projectId}}/suites", "host": ["{{API}}"], "path": ["api", "projects", "{{projectId}}", "suites"] } },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
