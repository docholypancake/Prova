          "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"\"\n}" }, "url": { "raw": "{{API}}/api/projects/{{projectId}}", "host": ["{{API}}"], "path": ["api", "projects", "{{projectId}}"] } }
        },
        {
          "name": "P14 PUT github -> 200",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200', () => pm.response.to.have.status(200));",
            "pm.test('github.owner set', () => pm.expect(pm.response.json().project.github.owner).to.eql('o'));"
          ] } }],
          "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"github\": { \"owner\": \"o\", \"repo\": \"r\" }\n}" }, "url": { "raw": "{{API}}/api/projects/{{projectId}}", "host": ["{{API}}"], "path": ["api", "projects", "{{projectId}}"] } }
        }
      ]
    },
